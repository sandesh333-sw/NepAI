# MongoDB Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/nepai?retryWrites=true&w=majority

# OpenAI API
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# Session Secret (generate a random string)
SESSION_SECRET=your-super-secret-random-string-change-this-to-something-secure

# Mailtrap Email Configuration (FREE for testing!)
# Get credentials from: https://mailtrap.io → Email Testing → Inboxes → SMTP Settings
MAILTRAP_USER=your-mailtrap-username
MAILTRAP_PASS=your-mailtrap-password
MAILTRAP_HOST=smtp.mailtrap.io
MAILTRAP_PORT=2525

# Google OAuth (Optional - only if you want Google sign-in)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Environment
NODE_ENV=development
